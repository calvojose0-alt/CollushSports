# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project credentials
# Get these values from: Firebase Console → Project Settings → Your Apps → Web App

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# OpenF1 API (free, no key required — but include base URL for clarity)
VITE_OPENF1_API_URL=https://api.openf1.org/v1

# App Mode: 'demo' uses mock data, 'live' uses Firebase + OpenF1 API
VITE_APP_MODE=demo
