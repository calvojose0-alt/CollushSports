# Supabase Configuration
# Copy this file to .env.local and fill in your Supabase project credentials
# Get these values from: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenF1 API (free, no key required — but include base URL for clarity)
VITE_OPENF1_API_URL=https://api.openf1.org/v1

# App Mode: 'demo' uses localStorage mock data, 'live' uses Supabase + OpenF1 API
VITE_APP_MODE=demo
